# EC Platform — 環境變數設定
# 複製此檔為 .env 並填入實際值
# 或使用 scripts/switch-tenant.sh 自動產生
# 詳見 docs/tenant-integration-guide.md

# ── 前端公開變數（VITE_ 前綴，會被打包進 JS）──
VITE_API_BASE=https://ai-go.app/api/v1
VITE_APP_SLUG=

# ── 伺服器端腳本專用（不暴露於前端）──
AIGO_API_KEY=
AIGO_BUILDER_EMAIL=
AIGO_BUILDER_PASSWORD=

# ── 僅 setup-references.mjs 使用（選填）──
# AIGO_APP_ID=
